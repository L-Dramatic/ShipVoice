# ShipVoice runtime profile for a remote ShipVoice LoRA LLM service.
# Copy to configs/runtime.real.env after filling endpoint host values.

SHIPVOICE_ASR_PROVIDER=http_json
SHIPVOICE_ASR_ENDPOINT=http://<server-ip>:8001/asr

SHIPVOICE_LLM_PROVIDER=openai_compatible
SHIPVOICE_OPENAI_BASE_URL=http://<server-ip>:11434/v1
SHIPVOICE_LLM_MODEL=shipvoice-qwen2.5-7b-lora
SHIPVOICE_REQUIRE_LORA=1
SHIPVOICE_REQUIRE_LLM_MODEL_SUBSTRING=shipvoice
# Optional strict attestation. Set this from LLM /health adapter_sha256 after deployment.
# SHIPVOICE_LORA_ADAPTER_SHA256=

SHIPVOICE_TTS_PROVIDER=http_json
SHIPVOICE_TTS_ENDPOINT=http://<server-ip>:8002/tts
SHIPVOICE_TTS_VOICE=zh-CN-XiaoxiaoNeural

SHIPVOICE_ADMIN_PASSWORD=<set-a-strong-admin-password>
SHIPVOICE_ADMIN_SESSION_SECRET=<set-a-random-32-byte-secret>
SHIPVOICE_APP_PORT=8022
