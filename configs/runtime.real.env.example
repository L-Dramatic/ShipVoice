# ShipVoice real-service profile example
# Copy to configs/runtime.real.env and fill the actual endpoints before use.

SHIPVOICE_ASR_PROVIDER=http_json
SHIPVOICE_ASR_ENDPOINT=http://<server-ip>:8001/asr

SHIPVOICE_LLM_PROVIDER=openai_compatible
SHIPVOICE_OPENAI_BASE_URL=http://<llm-host>:11434/v1
SHIPVOICE_LLM_MODEL=qwen2.5:7b-instruct
# SHIPVOICE_OPENAI_API_KEY=

SHIPVOICE_TTS_PROVIDER=http_json
SHIPVOICE_TTS_ENDPOINT=http://<server-ip>:8002/tts

SHIPVOICE_APP_PORT=8022
